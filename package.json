{
  "name": "adarsh-shoes-billing",
  "version": "1.0.0",
  "description": "Offline Billing Software for Adarsh Shoes",
  "author": "Your Name",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:report": "npx playwright test && npx playwright show-report",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && node packaging/win-build-electron.js",
    "build:release": "npm run electron:build",
    "build:test": "cd dist/GajrajKirana && node launcher.js"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.adarshshoes.billing",
    "productName": "Adarsh Shoes Billing",
    "icon": "public/favicon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "compression": "store",
    "files": [
      "electron/**/*",
      "public/favicon.ico",
      "public/logo.png"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": "public/favicon.ico",
        "to": "standalone/public/favicon.ico"
      },
      {
        "from": "public/logo.png",
        "to": "standalone/public/logo.png"
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "node_modules/better-sqlite3"
      },
      {
        "from": "node_modules/bindings",
        "to": "node_modules/bindings"
      },
      {
        "from": "node_modules/file-uri-to-path",
        "to": "node_modules/file-uri-to-path"
      }
    ],
    "win": {
      "icon": "public/favicon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.24",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "html2canvas-pro": "^2.0.4",
    "input-otp": "^1.4.2",
    "jimp": "^1.6.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "next": "^14.2.15",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^9.11.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.1",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.0",
    "eslint": "^9",
    "eslint-config-next": "^14.2.15",
    "innosetup-compiler": "^6.3.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "terser-webpack-plugin": "^5.6.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
